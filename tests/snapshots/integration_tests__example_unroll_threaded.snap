=== Neurons ===

neuron TransformerStack(d_model, num_heads, d_ff, num_layers = 6):
  inputs:
    default: [*, seq, d_model]
  outputs:
    default: [*, seq, d_model]
  graph:
    in -> unroll(num_layers): -> TransformerBlock#0(d_model, num_heads, d_ff) -> out
