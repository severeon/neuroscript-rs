source: tests/integration_tests.rs
expression: formatted
---
=== Neurons ===

neuron AdaptiveEncoder:
  inputs:
    default: [*shape]
  outputs:
    default: [*, 512]
  graph:
    in -> match:
      [*, 512]: Identity#80() -> out
      [*, d] where (d > 2048): Linear#81(d, 1024) -> Linear#82(1024, 512) -> out
      [*, d] where (d > 512): Linear#83(d, 512) -> out
      [*, d]: Linear#84(d, 256) -> Linear#85(256, 512) -> out
      [*, *, 512]: Identity#86() -> out
      [*, *, d] where (d > 512): Linear#87(d, 512) -> out
      [*, *, d]: Linear#88(d, 512) -> out
      [*dims, d]: Linear#89(d, 512) -> out

neuron ArithmeticGuards:
  inputs:
    default: [*, *]
  outputs:
    default: [*, 512]
  graph:
    in -> match:
      [*, d] where (d > 512): Linear#49(d, 512) -> out
      [*, d] where (d > 128): Linear#50(d, 256) -> Linear#51(256, 512) -> out
      [*, d]: Linear#52(d, 128) -> Linear#53(128, 512) -> out

neuron BasicProjection:
  inputs:
    default: [*, *]
  outputs:
    default: [*, 512]
  graph:
    in -> match:
      [*, d]: Linear#0(d, 512) -> out

neuron BatchAware:
  inputs:
    default: [batch, dim]
  outputs:
    default: [batch, 512]
  graph:
    in -> match:
      [batch, 512]: Identity#61() -> out
      [batch, d]: Linear#62(d, 512) -> out

neuron ComparisonGuards:
  inputs:
    default: [*, *]
  outputs:
    default: [*, 512]
  graph:
    in -> match:
      [*, d] where (d > 1000): Linear#42(d, 512) -> out
      [*, d] where (d >= 500): Linear#43(d, 512) -> out
      [*, d] where (d == 256): Linear#44(d, 512) -> out
      [*, d] where (d <= 100): Linear#45(d, 512) -> out
      [*, d] where (d < 50): Linear#46(d, 512) -> out
      [*, d]: Linear#47(d, 512) -> out

neuron ComplexPipeline:
  inputs:
    default: [*, *]
  outputs:
    default: [*, 512]
  graph:
    in -> match:
      [*, d] where (d > 1024): LayerNorm#29(d) -> Linear#30(d, 512) -> Dropout#31(0.1) -> out
      [*, d] where (d > 256): Linear#32(d, 512) -> Dropout#33(0.1) -> out
      [*, d]: Linear#34(d, 512) -> out

neuron ConditionalProjection:
  inputs:
    default: [*, *]
  outputs:
    default: [*, 512]
  graph:
    in -> match:
      [*, d] where (d > 512): Linear#2(d, 512) -> out
      [*, d]: Linear#3(d, 256) -> Linear#4(256, 512) -> out

neuron Dropout(p):
  inputs:
    default: [*shape]
  outputs:
    default: [*shape]
  impl:
    Source: core,nn/Dropout

neuron ExactDimensionRouter:
  inputs:
    default: [*, *]
  outputs:
    default: [*, 512]
  graph:
    in -> match:
      [*, 768]: Linear#36(768, 512) -> out
      [*, 1024]: Linear#37(1024, 512) -> out
      [*, 1280]: Linear#38(1280, 512) -> out
      [*, 1600]: Linear#39(1600, 512) -> out
      [*, d]: Linear#40(d, 512) -> out

neuron ExhaustiveProjection:
  inputs:
    default: [*, *]
  outputs:
    default: [*, 512]
  graph:
    in -> match:
      [*, 512]: Identity#6() -> out
      [*, 256]: Linear#7(256, 512) -> out
      [*, 1024]: Linear#8(1024, 512) -> out
      [*, d]: Linear#9(d, 512) -> out

neuron HighRank:
  inputs:
    default: [*, *, *, *, *]
  outputs:
    default: [*, *, *, *, 512]
  graph:
    in -> match:
      [*, *, *, *, 512]: Identity#77() -> out
      [*, *, *, *, d]: Linear#78(d, 512) -> out

neuron Identity:
  inputs:
    default: [*shape]
  outputs:
    default: [*shape]
  impl:
    Source: core,nn/Identity

neuron LayerNorm(dim):
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  impl:
    Source: core,nn/LayerNorm

neuron Linear(in_dim, out_dim):
  inputs:
    default: [*, in_dim]
  outputs:
    default: [*, out_dim]
  impl:
    Source: core,nn/Linear

neuron MultiStageCompression:
  inputs:
    default: [*, *]
  outputs:
    default: [*, 128]
  graph:
    in -> match:
      [*, d] where (d > 2048): Linear#11(d, 1024) -> Linear#12(1024, 512) -> Linear#13(512, 128) -> out
      [*, d] where (d > 512): Linear#14(d, 256) -> Linear#15(256, 128) -> out
      [*, d] where (d > 128): Linear#16(d, 128) -> out
      [*, d]: Identity#17() -> out

neuron MultiTarget:
  inputs:
    default: [*, *]
  outputs:
    default: [*, *]
  graph:
    in -> match:
      [*, d] where (d > 1024): Linear#67(d, 512) -> out
      [*, d] where (d > 256): Linear#68(d, 256) -> out
      [*, d]: Linear#69(d, 128) -> out

neuron MultiWildcard:
  inputs:
    default: [*, *, *]
  outputs:
    default: [*, *, 512]
  graph:
    in -> match:
      [*, *, 512]: Identity#55() -> out
      [*, *, d]: Linear#56(d, 512) -> out

neuron OneDimensional:
  inputs:
    default: [*]
  outputs:
    default: [512]
  graph:
    in -> match:
      [512]: Identity#74() -> out
      [d]: Linear#75(d, 512) -> out

neuron RankAgnosticProjection:
  inputs:
    default: [*shape]
  outputs:
    default: [*shape]
  graph:
    in -> match:
      [*, 512]: Identity#23() -> out
      [*, *, 512]: Identity#24() -> out
      [*, d]: Linear#25(d, 512) -> out
      [*, *, d]: Linear#26(d, 512) -> out
      [*dims, d]: Linear#27(d, 512) -> out

neuron Seq2Seq:
  inputs:
    default: [*, seq, *]
  outputs:
    default: [*, seq, 512]
  graph:
    in -> match:
      [*, seq, 512]: Identity#64() -> out
      [*, seq, d]: Linear#65(d, 512) -> out

neuron SequenceProjection:
  inputs:
    default: [*, *, *]
  outputs:
    default: [*, *, 512]
  graph:
    in -> match:
      [*, s, d] where (d < 512): Linear#19(d, 512) -> out
      [*, s, d] where (d == 512): Identity#20() -> out
      [*, s, d]: Linear#21(d, 512) -> out

neuron ShapePreserving:
  inputs:
    default: [*, *]
  outputs:
    default: [*, 512]
  graph:
    in -> match:
      [*, 512]: Identity#58() -> out
      [*, d]: Linear#59(d, 512) -> out

neuron VariadicWithGuard:
  inputs:
    default: [*shape]
  outputs:
    default: [*shape]
  graph:
    in -> match:
      [*dims, d] where (d > 512): Linear#71(d, 512) -> out
      [*dims, d]: Identity#72() -> out
