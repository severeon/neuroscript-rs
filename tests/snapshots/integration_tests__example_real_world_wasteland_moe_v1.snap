=== Neurons ===

neuron MoEBlock(dim, num_heads, kv_heads, num_experts, active_experts, expert_dim):
  inputs:
    default: [batch, seq, dim]
  outputs:
    default: [batch, seq, dim]
  graph:
    in -> (skip1, attn_path)
    attn_path -> RMSNorm#0(dim)
    RMSNorm#0(dim) -> GroupedQueryAttention#1(dim, num_heads, kv_heads)
    GroupedQueryAttention#1(dim, num_heads, kv_heads) -> attn_out
    (skip1, attn_out) -> Add#2()
    Add#2() -> mid
    mid -> (skip2, moe_path)
    moe_path -> RMSNorm#3(dim)
    RMSNorm#3(dim) -> MoERouter#4(dim, num_experts, active_experts, expert_dim)
    MoERouter#4(dim, num_experts, active_experts, expert_dim) -> moe_out
    (skip2, moe_out) -> Add#5()
    Add#5() -> out

neuron WastelandMoEV1(vocab_size = 32000, dim = 1024, num_heads = 16, kv_heads = 4, num_experts = 16, active_experts = 4, expert_dim = 1024, layers = 24):
  inputs:
    default: [batch, seq]
  outputs:
    default: [batch, seq, vocab_size]
  graph:
    in -> Embedding#6(vocab_size, dim)
    Embedding#6(vocab_size, dim) -> stack
    stack -> RMSNorm#7(dim)
    RMSNorm#7(dim) -> Linear#8(dim, vocab_size)
    Linear#8(dim, vocab_size) -> out
