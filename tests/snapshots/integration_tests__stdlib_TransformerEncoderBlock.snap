=== Neurons ===

neuron TransformerEncoderBlock(dim, num_heads, d_ff, dropout_rate):
  inputs:
    default: [batch, seq, dim]
  outputs:
    default: [batch, seq, dim]
  graph:
    in -> (attn_path, skip1)
    attn_path -> LayerNorm#0(dim)
    LayerNorm#0(dim) -> MultiHeadSelfAttention#1(dim, num_heads)
    MultiHeadSelfAttention#1(dim, num_heads) -> Dropout#2(dropout_rate)
    Dropout#2(dropout_rate) -> attn_out
    (attn_out, skip1) -> Add#3()
    Add#3() -> attn_residual
    attn_residual -> (ffn_path, skip2)
    ffn_path -> LayerNorm#4(dim)
    LayerNorm#4(dim) -> Linear#5(dim, d_ff)
    Linear#5(dim, d_ff) -> GELU#6()
    GELU#6() -> Dropout#7(dropout_rate)
    Dropout#7(dropout_rate) -> Linear#8(d_ff, dim)
    Linear#8(d_ff, dim) -> Dropout#9(dropout_rate)
    Dropout#9(dropout_rate) -> ffn_out
    (ffn_out, skip2) -> Add#10()
    Add#10() -> out
