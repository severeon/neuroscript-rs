---
source: tests/integration_tests.rs
expression: formatted
---
=== Uses ===
use nn::* (source: core)

=== Neurons ===

neuron AdaptiveLayerNorm:
  inputs:
    default: [*, *]
  outputs:
    default: [*, *]
  graph:
    in -> match:
      [32, 768]: LayerNorm#0(768) -> out
      [*, 768]: LayerNorm#1(768) -> out
      [*, d]: LayerNorm#2(d) -> out

neuron ConditionalProjection:
  inputs:
    default: [*, d]
  outputs:
    default: [*, 512]
  graph:
    in -> match:
      [*, d] where (d > 1024): Linear#4(d, 512) -> Linear#5(512, 512) -> out
      [*, d] where (d > 512): Linear#6(d, 512) -> out
      [*, d]: Linear#7(d, 256) -> Linear#8(256, 512) -> out

neuron OptimizedEncoder:
  inputs:
    default: [batch, seq, *]
  outputs:
    default: [batch, seq, 512]
  graph:
    in -> match:
      [*, *, 768]: Linear#10(768, 512) -> out
      [*, *, 256]: Linear#11(256, 512) -> out
      [*, *, d] where (d > 512): Linear#12(d, 512) -> out
      [*, *, d]: Linear#13(d, 512) -> out

neuron StaticResolutionDemo:
  inputs:
    default: [batch, 768]
  outputs:
    default: [batch, 512]
  graph:
    in -> match:
      [*, 512]: Identity#15() -> Linear#16(512, 512) -> out
      [*, 768]: Linear#17(768, 512) -> out
      [*, d]: Linear#18(d, 256) -> Linear#19(256, 512) -> out
