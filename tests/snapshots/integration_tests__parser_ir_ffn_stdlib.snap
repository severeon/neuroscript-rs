    ReLU#27() -> gate_signal
    value_path -> Linear#28(dim, expansion)
    Linear#28(dim, expansion) -> value_signal
    (gate_signal, value_signal) -> Multiply#29()
    Multiply#29() -> activated
    activated -> Linear#30(expansion, dim)
    Linear#30(expansion, dim) -> out

neuron SwiGLU(dim, expansion):
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  graph:
    in -> Fork#13()
    Fork#13() -> (gate_path, value_path)
    gate_path -> Linear#14(dim, expansion)
    Linear#14(dim, expansion) -> SiLU#15()
    SiLU#15() -> gate_signal
    value_path -> Linear#16(dim, expansion)
    Linear#16(dim, expansion) -> value_signal
