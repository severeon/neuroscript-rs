=== Uses ===
use nn::* (source: core)

=== Neurons ===

neuron GPT(vocab_size, d_model, num_heads, d_ff, max_seq_len):
  inputs:
    default: [batch, seq]
  outputs:
    default: [batch, seq, vocab_size]
  graph:
    in -> Embedding#0(vocab_size, d_model)
    Embedding#0(vocab_size, d_model) -> embedded
    embedded -> PositionalEncoding#1(d_model, max_len=max_seq_len)
    PositionalEncoding#1(d_model, max_len=max_seq_len) -> positioned
    positioned -> TransformerBlock#2(d_model, num_heads, d_ff)
    TransformerBlock#2(d_model, num_heads, d_ff) -> TransformerBlock#3(d_model, num_heads, d_ff)
    TransformerBlock#3(d_model, num_heads, d_ff) -> TransformerBlock#4(d_model, num_heads, d_ff)
    TransformerBlock#4(d_model, num_heads, d_ff) -> TransformerBlock#5(d_model, num_heads, d_ff)
    TransformerBlock#5(d_model, num_heads, d_ff) -> TransformerBlock#6(d_model, num_heads, d_ff)
    TransformerBlock#6(d_model, num_heads, d_ff) -> TransformerBlock#7(d_model, num_heads, d_ff)
    TransformerBlock#7(d_model, num_heads, d_ff) -> TransformerBlock#8(d_model, num_heads, d_ff)
    TransformerBlock#8(d_model, num_heads, d_ff) -> TransformerBlock#9(d_model, num_heads, d_ff)
    TransformerBlock#9(d_model, num_heads, d_ff) -> TransformerBlock#10(d_model, num_heads, d_ff)
    TransformerBlock#10(d_model, num_heads, d_ff) -> TransformerBlock#11(d_model, num_heads, d_ff)
    TransformerBlock#11(d_model, num_heads, d_ff) -> TransformerBlock#12(d_model, num_heads, d_ff)
    TransformerBlock#12(d_model, num_heads, d_ff) -> TransformerBlock#13(d_model, num_heads, d_ff)
    TransformerBlock#13(d_model, num_heads, d_ff) -> features
    features -> LayerNorm#14(d_model)
    LayerNorm#14(d_model) -> normalized
    normalized -> Linear#15(d_model, vocab_size)
    Linear#15(d_model, vocab_size) -> out

neuron GPT2Small(vocab_size):
  inputs:
    default: [batch, seq]
  outputs:
    default: [batch, seq, dim]
  graph:
    in -> GPT#16(vocab_size, 768, 12, 3072, 1024)
    GPT#16(vocab_size, 768, 12, 3072, 1024) -> out

neuron TinyGPT(vocab_size):
  inputs:
    default: [batch, seq]
  outputs:
    default: [batch, seq, dim]
  graph:
    in -> GPT#17(vocab_size, 256, 4, 1024, 512)
    GPT#17(vocab_size, 256, 4, 1024, 512) -> out
