=== Neurons ===

neuron Identity:
  inputs:
    default: [*shape]
  outputs:
    default: [*shape]
  impl:
    Source: core,builtin/Identity

neuron Linear(in_dim, out_dim):
  inputs:
    default: [*, in_dim]
  outputs:
    default: [*, out_dim]
  impl:
    Source: core,nn/Linear

neuron TestShadowing:
  inputs:
    default: [*, dim]
  outputs:
    default: [*, 512]
  graph:
    in -> match:
      [*, 512]: Identity#0()
      [*, 256]: Linear#1(256, 512)
      [*, 1024]: Linear#2(1024, 512)
      [*, d]: Linear#3(d, 512)
    match:
      [*, 512]: Identity#0()
      [*, 256]: Linear#1(256, 512)
      [*, 1024]: Linear#2(1024, 512)
      [*, d]: Linear#3(d, 512) -> out
