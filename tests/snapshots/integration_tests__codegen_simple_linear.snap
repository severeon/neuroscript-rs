import torch
import torch.nn as nn
from neuroscript_runtime.primitives.linear import Linear

class SimpleLinear(nn.Module):
    def __init__(self):
        super().__init__()
        self.linear_0 = Linear(512, 256)

    def forward(self, x):
        linear_0 = self.linear_0(x)
        # Linear() output shape: [*, out_dim]
        return linear_0
