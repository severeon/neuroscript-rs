---
source: tests/integration_tests.rs
expression: formatted
---
=== Neurons ===

neuron Add:
  inputs:
    left: [*shape]
    right: [*shape]
  outputs:
    default: [*shape]
  impl:
    Source: core,nn/Add

neuron Concat(dim):
  inputs:
    a: [*shape]
    b: [*shape]
  outputs:
    default: [*shape]
  impl:
    Source: core,nn/Concat

neuron ConcatTest(dim):
  inputs:
    default: [batch, seq, dim]
  outputs:
    default: [batch, seq, (dim * 2)]
  graph:
    in -> Fork#3()
    Fork#3() -> (a, b)
    (a, b) -> Concat#4((0 - 1))
    Concat#4((0 - 1)) -> out

neuron Fork:
  inputs:
    default: [*shape]
  outputs:
    a: [*shape]
    b: [*shape]
  impl:
    Source: core,nn/Fork

neuron Linear(in_features, out_features):
  inputs:
    default: [*, in_features]
  outputs:
    default: [*, out_features]
  impl:
    Source: core,nn/Linear

neuron ScaledDotProductAttention:
  inputs:
    query: [*batch, seq_q, d_k]
    key: [*batch, seq_k, d_k]
    value: [*batch, seq_k, d_v]
  outputs:
    default: [*batch, seq_q, d_v]
  impl:
    Source: core,nn/ScaledDotProductAttention

neuron SelfAttention(d_model):
  inputs:
    default: [batch, seq, d_model]
  outputs:
    default: [batch, seq, d_model]
  graph:
    in -> Fork#5()
    Fork#5() -> (q, k_v)
    k_v -> Fork#6()
    Fork#6() -> (k, v)
    (q, k, v) -> ScaledDotProductAttention#7()
    ScaledDotProductAttention#7() -> out

neuron SimpleResidual(dim):
  inputs:
    default: [batch, seq, dim]
  outputs:
    default: [batch, seq, dim]
  graph:
    in -> Fork#0()
    Fork#0() -> (main, skip)
    main -> Linear#1(dim, dim)
    Linear#1(dim, dim) -> processed
    (processed, skip) -> Add#2()
    Add#2() -> out
