---
source: tests/integration_tests.rs
expression: formatted
---
=== Neurons ===

neuron Add:
  inputs:
    left: [*shape]
    right: [*shape]
  outputs:
    default: [*shape]
  impl:
    Source: core,builtin/Add

neuron Concat:
  inputs:
    a: [*, dim_a]
    b: [*, dim_b]
    c: [*, dim_c]
  outputs:
    default: [*, (dim_a + dim_b)]
  impl:
    Source: core,builtin/Concat

neuron Fork:
  inputs:
    default: [*shape]
  outputs:
    a: [*shape]
    b: [*shape]
  impl:
    Source: core,builtin/Fork

neuron Fork3:
  inputs:
    default: [*shape]
  outputs:
    a: [*shape]
    b: [*shape]
    c: [*shape]
  impl:
    Source: core,builtin/Fork3

neuron GELU:
  inputs:
    default: [*shape]
  outputs:
    default: [*shape]
  impl:
    Source: core,activations/GELU

neuron LayerNorm(dim):
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  impl:
    Source: core,normalization/LayerNorm

neuron Linear(in_dim, out_dim):
  inputs:
    default: [*, in_dim]
  outputs:
    default: [*, out_dim]
  impl:
    Source: core,nn/Linear

neuron NestedResidual(dim):
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  graph:
    in -> Fork#12()
    Fork#12() -> (outer_main, outer_skip)
    outer_main -> Fork#13()
    Fork#13() -> (inner_main, inner_skip)
    inner_main -> Linear#14(dim, dim)
    Linear#14(dim, dim) -> inner_processed
    (inner_processed, inner_skip) -> Add#15()
    Add#15() -> inner_sum
    (inner_sum, outer_skip) -> Add#16()
    Add#16() -> out

neuron ParallelProcessing(dim):
  inputs:
    default: [*, dim]
  outputs:
    default: [*, (dim * 3)]
  graph:
    in -> Fork3#7()
    Fork3#7() -> (path1, path2, path3)
    path1 -> Linear#8(dim, dim)
    Linear#8(dim, dim) -> p1
    path2 -> Linear#9(dim, dim)
    Linear#9(dim, dim) -> p2
    path3 -> Linear#10(dim, dim)
    Linear#10(dim, dim) -> p3
    (p1, p2, p3) -> Concat#11()
    Concat#11() -> out

neuron PreActivationResidual(dim):
  inputs:
    default: [batch, dim]
  outputs:
    default: [batch, dim]
  graph:
    in -> Fork#17()
    Fork#17() -> (main, skip)
    main -> LayerNorm#18(dim)
    LayerNorm#18(dim) -> Linear#19(dim, (dim * 4))
    Linear#19(dim, (dim * 4)) -> GELU#20()
    GELU#20() -> Linear#21((dim * 4), dim)
    Linear#21((dim * 4), dim) -> processed
    (processed, skip) -> Add#22()
    Add#22() -> out

neuron ResidualBlock(dim):
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  graph:
    in -> Fork#2()
    Fork#2() -> (main, skip)
    main -> Linear#3(dim, (dim * 4))
    Linear#3(dim, (dim * 4)) -> GELU#4()
    GELU#4() -> Linear#5((dim * 4), dim)
    Linear#5((dim * 4), dim) -> processed
    (processed, skip) -> Add#6()
    Add#6() -> out

neuron SimpleFork:
  inputs:
    default: [*, dim]
  outputs:
    a: [*, dim]
    b: [*, dim]
  impl:
    Source: core,builtin/Fork

neuron ThreeWayFork:
  inputs:
    default: [*, dim]
  outputs:
    a: [*, dim]
    b: [*, dim]
    c: [*, dim]
  impl:
    Source: core,builtin/Fork3

neuron UnpackExample(dim):
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  graph:
    in -> Fork#0()
    Fork#0() -> (main, skip)
    main -> Linear#1(dim, dim)
    Linear#1(dim, dim) -> out
