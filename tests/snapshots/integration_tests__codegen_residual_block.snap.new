import torch
import torch.nn as nn
from neuroscript_runtime.primitives.activations import GELU
from neuroscript_runtime.primitives.linear import Linear
from neuroscript_runtime.primitives.structural import Add
from neuroscript_runtime.primitives.structural import Fork

class MLP(nn.Module):
    def __init__(self, dim):
        super().__init__()
        self.dim = dim
        self.g_e_l_u_1 = GELU()
        self.linear_0 = Linear(dim, dim * 4)
        self.linear_2 = Linear(dim * 4, dim)

    def forward(self, x):
        x0 = self.linear_0(x)
        # Linear() output shape: [*, out_dim]
        x1 = self.g_e_l_u_1(x0)
        # GELU() output shape: [*, out_dim]
        x2 = self.linear_2(x1)
        # Linear() output shape: [*, out_dim]
        return x2

class Residual(nn.Module):
    def __init__(self, dim):
        super().__init__()
        self.dim = dim
        self.add_2 = Add()
        self.fork_0 = Fork()
        self.m_l_p_1 = MLP(dim)

    def forward(self, x):
        x0 = self.fork_0(x)
        # Fork() output shape: [*, dim]
        x1, x2 = x0
        x3 = self.m_l_p_1(x1)
        # MLP() output shape: [*, dim]
        # Expected shape: [*, dim]
        x4 = self.add_2((x3, x2))
        # Add() output shape: [*, dim]
        return x4
