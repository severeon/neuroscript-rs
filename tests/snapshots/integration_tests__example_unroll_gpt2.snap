=== Neurons ===

neuron GPT2Small(vocab_size = 50257, d_model = 768, num_heads = 12, d_ff = 3072, num_layers = 12):
  inputs:
    default: [*, seq]
  outputs:
    default: [*, seq, vocab_size]
  context:
    embed = Embedding(...)
    ln_f = LayerNorm(...)
    head = Linear(...)
  graph:
    in -> embed
    embed -> unroll(num_layers): -> block -> ln_f -> head -> out
