neuron RegularizationStack(dim):
  inputs:
    default: [batch, seq, dim]
  outputs:
    default: [batch, seq, dim]
  graph:
    in -> Dropout#23(0.1)
    Dropout#23(0.1) -> DropConnect#24(0.05)
    DropConnect#24(0.05) -> out

neuron ResidualFFN(dim, hidden_dim):
  inputs:
    default: [*batch, dim]
  outputs:
    default: [*batch, dim]
  graph:
    in -> Fork#13()
    Fork#13() -> (main, skip)
    main -> LayerNorm#14(dim)
    LayerNorm#14(dim) -> Linear#15(dim, hidden_dim)
    Linear#15(dim, hidden_dim) -> GELU#16()
    GELU#16() -> Linear#17(hidden_dim, dim)
    Linear#17(hidden_dim, dim) -> Dropout#18(0.1)
    Dropout#18(0.1) -> processed
    (skip, processed) -> Add#19()
    Add#19() -> out

