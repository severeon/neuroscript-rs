neuron TransformerFFN(dim, hidden_dim):
  inputs:
    default: [*batch, dim]
  outputs:
    default: [*batch, dim]
  graph:
    in -> Fork#25()
    Fork#25() -> (main, skip)
    main -> LayerNorm#26(dim)
    LayerNorm#26(dim) -> Linear#27(dim, hidden_dim)
    Linear#27(dim, hidden_dim) -> GELU#28()
    GELU#28() -> Dropout#29(0.1)
    Dropout#29(0.1) -> Linear#30(hidden_dim, dim)
    Linear#30(hidden_dim, dim) -> Dropout#31(0.1)
    Dropout#31(0.1) -> processed
    (skip, processed) -> Add#32()
    Add#32() -> out
