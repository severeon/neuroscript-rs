neuron FiveWayImplicitFork(dim):
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  graph:
    in -> (a, b, c, d, e)
    a -> Linear#14(dim, dim)
    Linear#14(dim, dim) -> pa
    b -> Linear#15(dim, dim)
    Linear#15(dim, dim) -> pb
    (pa, pb) -> Add#16()
    Add#16() -> ab
    c -> Linear#17(dim, dim)
    Linear#17(dim, dim) -> pc
    (ab, pc) -> Add#18()
    Add#18() -> abc
    d -> Linear#19(dim, dim)
    Linear#19(dim, dim) -> pd
    (abc, pd) -> Add#20()
    Add#20() -> abcd
    e -> Linear#21(dim, dim)
    Linear#21(dim, dim) -> pe
    (abcd, pe) -> Add#22()
    Add#22() -> out

