=== Neurons ===

neuron Add:
  inputs:
    a: [*shape]
    b: [*shape]
  outputs:
    default: [*shape]
  graph:
    a -> Identity#3()
    Identity#3() -> out

neuron Concatenate(dim):
  inputs:
    default: [*tensors]
  outputs:
    default: [*concatenated_shape]
  graph:
    in -> Identity#2()
    Identity#2() -> out

neuron Fork(num_paths):
  inputs:
    default: [*shape]
  outputs:
    default: [*shapes]
  graph:
    in -> Identity#9()
    Identity#9() -> out

neuron Identity:
  inputs:
    default: [*shape]
  outputs:
    default: [*shape]
  graph:
    in -> out

neuron Merge(operation):
  inputs:
    default: [*tensors]
  outputs:
    default: [*shape]
  graph:
    in -> Identity#10()
    Identity#10() -> out

neuron MultiPathNet(dim):
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  graph:
    in -> Fork#14(3)
    Fork#14(3) -> (path1, path2, path3)
    path1 -> Linear#15(dim, dim)
    Linear#15(dim, dim) -> out1
    path2 -> FFN#16(dim, (dim * 2))
    FFN#16(dim, (dim * 2)) -> out2
    path3 -> Identity#17()
    Identity#17() -> out3

neuron Multiply:
  inputs:
    a: [*shape]
    b: [*shape]
  outputs:
    default: [*shape]
  graph:
    a -> Identity#4()
    Identity#4() -> out

neuron Parallel(neurons):
  inputs:
    default: [*shape]
  outputs:
    default: [*shapes]
  graph:
    in -> Identity#1()
    Identity#1() -> out

neuron ParallelFFN(dim):
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  graph:
    in -> FFN#12(dim, (dim * 2))
    FFN#12(dim, (dim * 2)) -> out

neuron Repeat(f, n):
  inputs:
    default: [*shape]
  outputs:
    default: [*shape]
  graph:
    in -> Identity#8()
    Identity#8() -> out

neuron Reshape(target_shape):
  inputs:
    default: [*shape_in]
  outputs:
    default: [*target_shape]
  graph:
    in -> Identity#6()
    Identity#6() -> out

neuron Sequential(neurons):
  inputs:
    default: [*shape_in]
  outputs:
    default: [*shape_out]
  graph:
    in -> Identity#0()
    Identity#0() -> out

neuron SequentialTransformer(num_layers, dim):
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  graph:
    in -> TransformerBlock#13(dim, 8, (dim * 4))
    TransformerBlock#13(dim, 8, (dim * 4)) -> out

neuron Split(dim, num_splits):
  inputs:
    default: [*shape]
  outputs:
    default: [*split_shapes]
  graph:
    in -> Identity#5()
    Identity#5() -> out

neuron Switch(condition, true_path, false_path):
  inputs:
    default: [*shape]
  outputs:
    default: [*shape]
  graph:
    in -> Identity#11()
    Identity#11() -> out

neuron Transpose(dim0, dim1):
  inputs:
    default: [*shape]
  outputs:
    default: [*transposed_shape]
  graph:
    in -> Identity#7()
    Identity#7() -> out
