=== Neurons ===

neuron DuplicateBinding(dim):
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  context:
    layer = Linear(...)
    layer = Linear(...)
  graph:
    in -> layer
    layer -> out

neuron MissingInLet(dim):
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  context:
    @lazy missing = NonExistentNeuron(...)
  graph:
    in -> missing
    missing -> out

neuron MissingInSet(dim):
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  context:
    missing = AnotherNonExistent(...)
  graph:
    in -> missing
    missing -> out

neuron RecursiveSet(dim):
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  context:
    recurse = RecursiveSet(...)
  graph:
    in -> recurse
    recurse -> out
