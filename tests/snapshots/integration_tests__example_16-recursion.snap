=== Uses ===
use nn::Identity (source: core)

=== Neurons ===

neuron Identity:
  inputs:
    default: [*]
  outputs:
    default: [*]
  impl:
    Source: core,nn/Identity

neuron MyNeuron(d_model, num_heads, d_ff, depth):
  inputs:
    default: [*, seq, d_model]
  outputs:
    default: [*, seq, d_model]
  context:
    @lazy recurse = MyNeuron(...)
  graph:
    in -> match:
      [*, seq, d_model] where (depth > 0): recurse
      [*, seq, d_model]: Identity#0() -> out
