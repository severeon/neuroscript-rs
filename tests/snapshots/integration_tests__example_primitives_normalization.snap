source: tests/integration_tests.rs
expression: formatted
---
=== Neurons ===

neuron Add:
  inputs:
    left: [*shape]
    right: [*shape]
  outputs:
    default: [*shape]
  impl:
    Source: core,builtin/Add

neuron BatchNorm(dim):
  inputs:
    default: [*shape, dim]
  outputs:
    default: [*shape, dim]
  impl:
    Source: core,normalization/BatchNorm

neuron Conv2d(in_channels, out_channels, kernel_size, padding):
  inputs:
    default: [*, in_channels, h, w]
  outputs:
    default: [*, out_channels, h, w]
  impl:
    Source: core,nn/Conv2d

neuron ConvBlock(in_channels, out_channels):
  inputs:
    default: [*, in_channels, h, w]
  outputs:
    default: [*, out_channels, h, w]
  graph:
    in -> Conv2d#11(in_channels, out_channels, kernel_size=3, padding=1)
    Conv2d#11(in_channels, out_channels, kernel_size=3, padding=1) -> BatchNorm#12(out_channels)
    BatchNorm#12(out_channels) -> ReLU#13()
    ReLU#13() -> out

neuron Fork:
  inputs:
    default: [*shape]
  outputs:
    a: [*shape]
    b: [*shape]
  impl:
    Source: core,builtin/Fork

neuron GroupNorm(num_groups, dim):
  inputs:
    default: [*shape, dim]
  outputs:
    default: [*shape, dim]
  impl:
    Source: core,normalization/GroupNorm

neuron GroupNormBlock(channels, num_groups):
  inputs:
    default: [*, channels, h, w]
  outputs:
    default: [*, channels, h, w]
  graph:
    in -> Conv2d#14(channels, channels, kernel_size=3, padding=1)
    Conv2d#14(channels, channels, kernel_size=3, padding=1) -> GroupNorm#15(num_groups, channels)
    GroupNorm#15(num_groups, channels) -> ReLU#16()
    ReLU#16() -> out

neuron InstanceNorm(dim):
  inputs:
    default: [*shape, dim]
  outputs:
    default: [*shape, dim]
  impl:
    Source: core,normalization/InstanceNorm

neuron LLaMAStyleBlock(dim):
  inputs:
    default: [*, seq, dim]
  outputs:
    default: [*, seq, dim]
  graph:
    in -> (main, skip)
    main -> RMSNorm#6(dim)
    RMSNorm#6(dim) -> Linear#7(dim, (dim * 4))
    Linear#7(dim, (dim * 4)) -> SiLU#8()
    SiLU#8() -> Linear#9((dim * 4), dim)
    Linear#9((dim * 4), dim) -> processed
    (processed, skip) -> Add#10()
    Add#10() -> out

neuron LayerNorm(dim):
  inputs:
    default: [*shape, dim]
  outputs:
    default: [*shape, dim]
  impl:
    Source: core,normalization/LayerNorm

neuron Linear(in_dim, out_dim):
  inputs:
    default: [*shape, in_dim]
  outputs:
    default: [*shape, out_dim]
  impl:
    Source: core,nn/Linear

neuron PostNormBlock(dim):
  inputs:
    default: [*, seq, dim]
  outputs:
    default: [*, seq, dim]
  graph:
    in -> (main, skip)
    main -> Linear#3(dim, dim)
    Linear#3(dim, dim) -> processed
    (processed, skip) -> Add#4()
    Add#4() -> LayerNorm#5(dim)
    LayerNorm#5(dim) -> out

neuron PreNormBlock(dim):
  inputs:
    default: [*, seq, dim]
  outputs:
    default: [*, seq, dim]
  graph:
    in -> (main, skip)
    main -> LayerNorm#0(dim)
    LayerNorm#0(dim) -> Linear#1(dim, dim)
    Linear#1(dim, dim) -> processed
    (processed, skip) -> Add#2()
    Add#2() -> out

neuron RMSNorm(dim):
  inputs:
    default: [*shape, dim]
  outputs:
    default: [*shape, dim]
  impl:
    Source: core,normalization/RMSNorm

neuron ReLU:
  inputs:
    default: [*shape]
  outputs:
    default: [*shape]
  impl:
    Source: core,activations/ReLU

neuron SiLU:
  inputs:
    default: [*shape]
  outputs:
    default: [*shape]
  impl:
    Source: core,activations/SiLU
