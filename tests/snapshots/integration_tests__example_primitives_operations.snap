source: tests/integration_tests.rs
expression: formatted
---
=== Neurons ===

neuron Add:
  inputs:
    left: [*shape]
    right: [*shape]
  outputs:
    default: [*shape]
  impl:
    Source: core,builtin/Add

neuron AttentionScore(dim):
  inputs:
    query: [batch, seq, dim]
    key: [batch, seq, dim]
  outputs:
    default: [batch, seq, seq]
  graph:
    (query, key) -> MatMul#9()
    MatMul#9() -> out

neuron Bias(dim):
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  impl:
    Source: core,builtin/Bias

neuron ComplexOperation(dim):
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  graph:
    in -> Fork#16()
    Fork#16() -> (path1, path2)
    path1 -> Linear#17(dim, dim)
    Linear#17(dim, dim) -> Bias#18(dim)
    Bias#18(dim) -> Scale#19(dim)
    Scale#19(dim) -> p1_out
    path2 -> Scale#20(dim)
    Scale#20(dim) -> p2_out
    (p1_out, p2_out) -> Multiply#21()
    Multiply#21() -> Add#22()
    Add#22() -> out

neuron Einsum(equation):
  inputs:
    a: [*shape_a]
    b: [*shape_b]
  outputs:
    default: [*shape_out]
  impl:
    Source: core,builtin/Einsum

neuron Fork:
  inputs:
    default: [*shape]
  outputs:
    a: [*shape]
    b: [*shape]
  impl:
    Source: core,builtin/Fork

neuron GatedUnit(dim, hidden_dim):
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  graph:
    in -> Fork#3()
    Fork#3() -> (gate_path, value_path)
    gate_path -> Linear#4(dim, hidden_dim)
    Linear#4(dim, hidden_dim) -> SiLU#5()
    SiLU#5() -> gate
    value_path -> Linear#6(dim, hidden_dim)
    Linear#6(dim, hidden_dim) -> value
    (gate, value) -> Multiply#7()
    Multiply#7() -> Linear#8(hidden_dim, dim)
    Linear#8(hidden_dim, dim) -> out

neuron Linear(in_dim, out_dim):
  inputs:
    default: [*, in_dim]
  outputs:
    default: [*, out_dim]
  impl:
    Source: core,nn/Linear

neuron LinearWithBias(in_dim, out_dim):
  inputs:
    default: [*, in_dim]
  outputs:
    default: [*, out_dim]
  graph:
    in -> Linear#10(in_dim, out_dim)
    Linear#10(in_dim, out_dim) -> Bias#11(out_dim)
    Bias#11(out_dim) -> out

neuron MatMul:
  inputs:
    a: [*, m, k]
    b: [*, k, n]
  outputs:
    default: [*, m, n]
  impl:
    Source: core,builtin/MatMul

neuron Multiply:
  inputs:
    a: [*shape]
    b: [*shape]
  outputs:
    default: [*shape]
  impl:
    Source: core,builtin/Multiply

neuron ResidualAdd(dim):
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  graph:
    in -> Fork#0()
    Fork#0() -> (main, skip)
    main -> Linear#1(dim, dim)
    Linear#1(dim, dim) -> processed
    (processed, skip) -> Add#2()
    Add#2() -> out

neuron Scale(dim):
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  impl:
    Source: core,builtin/Scale

neuron SiLU:
  inputs:
    default: [*shape]
  outputs:
    default: [*shape]
  impl:
    Source: core,activations/SiLU

neuron WeightedResidual(dim):
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  graph:
    in -> Fork#12()
    Fork#12() -> (main, skip)
    main -> Linear#13(dim, dim)
    Linear#13(dim, dim) -> processed
    processed -> Scale#14(dim)
    Scale#14(dim) -> scaled
    (scaled, skip) -> Add#15()
    Add#15() -> out
