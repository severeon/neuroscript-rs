use core,nn/*
use core,normalization/*
use core,attention/*
use core,activations/*
use core,regularization/*
use core,structural/*

# TransformerBlock from stdlib
# impl shown here for completeness
# and because it's sexy
neuron TransformerBlock(d_model, num_heads, d_ff):
    in: [batch, seq, d_model]
    out: [batch, seq, d_model]
    graph:
        # First residual-attention with pre-norm
        in -> Fork() -> (skip1, attn_path)

        attn_path ->
            LayerNorm(d_model)
            MultiHeadSelfAttention(d_model, num_heads)
            Dropout(0.1)
            attn_out

        # Add residual
        (skip1, attn_out) -> Add() -> attn_residual

        # Second residual-forward with pre-norm
        attn_residual -> Fork() -> (skip2, ffn_path)

        ffn_path ->
            LayerNorm(d_model)
            FFN(d_model, d_ff)
            Dropout(0.1)
            ffn_out

        # Add residual
        (skip2, ffn_out) -> Add() -> out


neuron TransformerStack12(dim, num_heads, d_ff):
    in: [batch, seq, dim]
    out: [batch, seq, dim]
    graph:
        in ->
            TransformerBlock(dim, num_heads, d_ff)
            TransformerBlock(dim, num_heads, d_ff)
            TransformerBlock(dim, num_heads, d_ff)
            TransformerBlock(dim, num_heads, d_ff)
            TransformerBlock(dim, num_heads, d_ff)
            TransformerBlock(dim, num_heads, d_ff)
            TransformerBlock(dim, num_heads, d_ff)
            TransformerBlock(dim, num_heads, d_ff)
            TransformerBlock(dim, num_heads, d_ff)
            TransformerBlock(dim, num_heads, d_ff)
            TransformerBlock(dim, num_heads, d_ff)
            TransformerBlock(dim, num_heads, d_ff)
            out

# GPT-2 Small: Single layer for testing
neuron GPT2Small(vocab_size):
    in: [batch, seq]
    out: [*, vocab_size]
    graph:
        in ->
            Embedding(vocab_size, 768)            # Token embeddings
            PositionalEncoding(768, max_len=1024) # Positional encoding
            TransformerStack12(768, 12, 3072)     # 12 transformer block
            LayerNorm(768)                        # Final layer norm
            Linear(768, vocab_size)               # Language model head
            out
