use core,nn/*
use core,normalization/*
use core,attention/*
use core,activations/*
use core,regularization/*
use core,structural/*

neuron TransformerStack12(dim, num_heads, d_ff):
    in: [batch, seq, dim]
    out: [batch, seq, dim]
    graph:
        in ->
            TransformerBlock(dim, num_heads, d_ff)
            TransformerBlock(dim, num_heads, d_ff)
            TransformerBlock(dim, num_heads, d_ff)
            TransformerBlock(dim, num_heads, d_ff)
            TransformerBlock(dim, num_heads, d_ff)
            TransformerBlock(dim, num_heads, d_ff)
            TransformerBlock(dim, num_heads, d_ff)
            TransformerBlock(dim, num_heads, d_ff)
            TransformerBlock(dim, num_heads, d_ff)
            TransformerBlock(dim, num_heads, d_ff)
            TransformerBlock(dim, num_heads, d_ff)
            TransformerBlock(dim, num_heads, d_ff)
            out

neuron GPT2Small(vocab_size):
    in: [batch, seq]
    out: [*, vocab_size]
    graph:
        in ->
            Embedding(vocab_size, 768)            # Token embeddings
            PositionalEncoding(768, max_len=1024) # Positional encoding
            TransformerStack12(768, 12, 3072)     # 12 transformer block
            LayerNorm(768)                        # Final layer norm
            Linear(768, vocab_size)               # Language model head
            out
