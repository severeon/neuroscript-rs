# Unroll: context-scoped bindings with graph-unroll reference
# Each unrolled binding gets a unique instance per iteration

# Stack with named bindings per layer
neuron NamedStack(d_model, num_heads, d_ff, num_layers=3):
    in: [*, seq, d_model]
    out: [*, seq, d_model]
    context:
        unroll(num_layers):
            block = TransformerBlock(d_model, num_heads, d_ff)
    graph:
        in ->
            unroll(num_layers): ->
                block
            out
