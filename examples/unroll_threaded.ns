# Unroll: threaded (sequential chaining)
# Demonstrates compile-time expansion of repeated layers

# Stack of 6 transformer blocks via unroll
neuron TransformerStack(d_model, num_heads, d_ff, num_layers=6):
    in: [*, seq, d_model]
    out: [*, seq, d_model]
    graph:
        in ->
            unroll(num_layers): ->
                TransformerBlock(d_model, num_heads, d_ff)
            out
