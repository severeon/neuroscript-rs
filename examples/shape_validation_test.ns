# Shape Validation Test Cases
# This file tests the shape compatibility validation

use core,nn/*

neuron Linear(in_dim, out_dim):
  in: [*, in_dim]
  out: [*, out_dim]
  impl: core,nn/Linear

neuron GELU:
  in: [*shape]
  out: [*shape]
  impl: core,activations/GELU

neuron Add:
  in left: [*shape]
  in right: [*shape]
  out: [*shape]
  impl: core,builtin/Add

neuron Fork:
  in: [*shape]
  out a: [*shape]
  out b: [*shape]
  impl: core,builtin/Fork

neuron Identity():
  in: [*any]
  out: [*any]
  impl: core,nn/Identity
  
neuron LayerNorm(normalized_shape):
  # Layer normalization
  # Operates on the last dimension of any input shape
  in: [*batch, normalized_shape]
  out: [*batch, normalized_shape]
  impl: core,nn/LayerNorm
  
# Test 1: Compatible shapes with dimension variables
neuron TestCompatible(dim):
  in input: [*, dim]
  out output: [*, dim]
  graph:
    # This should work - shapes match
    input -> Linear(dim, dim) -> output

# Test 2: Wildcard handling
neuron TestWildcard():
  in input: [*, *]
  out output: [*, *]
  graph:
    # Wildcards should match any dimension
    input -> Identity() -> output

# Test 3: Tuple unpacking with correct arity
neuron TestTupleCorrect():
  in input: [*, 512]
  out left: [*, 256]
  out right: [*, 256]
  graph:
    input -> Fork() -> (a, b)
    a -> Linear(512, 256) -> left
    b -> Linear(512, 256) -> right

# Test 4: Dimension unification
neuron TestDimUnification(d):
  in x: [*, d]
  in y: [*, d]
  out result: [*, d]
  graph:
    # Both inputs use 'd', they should unify
    (x, y) ->
      Add()
      temp
      result

# Test 5: Shape mismatch (should fail validation if we test it)
# Uncomment to test error detection:
neuron TestMismatch():
  in input: [*, 512]
  out output: [*, 256]
  graph:
    # ERROR: Linear(512, 256) outputs [*, 256] but we expect [*, 256]
    # This should actually work! Let me fix it:
    input -> Linear(512, 128) -> output  # ERROR: outputs [*, 128], expected [*, 256]

# Test 6: Rank mismatch (should fail)
neuron TestRankMismatch():
  in input: [*, 512]
  out output: [*, 256, 256]
  graph:
    input -> Linear(512, 256) -> output  # ERROR: Linear outputs [*, 256], expected [*, 256, 256]

# Test 7: Named dimension consistency
neuron TestNamedDims(batch, seq, dim):
  in input: [batch, seq, dim]
  out output: [batch, seq, dim]
  graph:
    # Dimension names should be consistent throughout
    input -> LayerNorm(dim) -> temp -> Linear(dim, dim) -> output
