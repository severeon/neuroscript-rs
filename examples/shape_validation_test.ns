# Shape Validation Test Cases
# This file tests the shape compatibility validation

# Test 1: Compatible shapes with dimension variables
neuron TestCompatible(dim):
    in input: [*, dim]
    out output: [*, dim]
    graph:
        # This should work - shapes match
        in -> Linear(dim, dim) -> out

# Test 2: Wildcard handling
neuron TestWildcard():
    in input: [*, *]
    out output: [*, *]
    graph:
        # Wildcards should match any dimension
        in -> Identity() -> out

# Test 3: Tuple unpacking with correct arity
neuron TestTupleCorrect():
    in input: [*, 512]
    out left: [*, 256]
    out right: [*, 256]
    graph:
        in -> Fork() -> (a, b)
        a -> Linear(512, 256) -> left
        b -> Linear(512, 256) -> right

# Test 4: Dimension unification
neuron TestDimUnification(d):
    in x: [*, d]
    in y: [*, d]
    out result: [*, d]
    graph:
        # Both inputs use 'd', they should unify
        x -> Add() -> temp
        y -> temp
        temp -> out

