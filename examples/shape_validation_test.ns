# Test 7: Named dimension consistency
neuron TestNamedDims(batch, seq, dim):
    in input: [batch, seq, dim]
    out output: [batch, seq, dim]
    graph:
        # Dimension names should be consistent throughout
        in -> LayerNorm(dim) -> temp
        temp -> Linear(dim, dim) -> out
