# Wasteland Coder v1 — "CodeTito-style Llama for code"
#
# Based on finding: CodeTito (Llama 3.2 3B fine-tune) scored 85/100 on coding.
# Architecture is standard Llama — it wins on training data, not structure.
# qwen2.5-coder:3b also scored 80/100 at 105 tok/s.
#
# This model replicates the winning code architecture at a smaller scale (~800M),
# targeting Swift/JS code generation for our specific projects.
#
# Architecture choices:
# - Llama-style: GQA + SwiGLU + RMSNorm + RoPE
# - 28 layers (CodeTito/Llama 3.2 depth)
# - dim=1024, 16 heads, 4 KV heads (4:1 GQA — aggressive for speed)
# - d_ff = 2816 (2.75x expansion — between Llama's 2.67x and 4x)
# - Smaller vocab (16K) — code has limited vocabulary vs natural language
#
# Key insight from benchmarks: for coding tasks, the model needs enough
# depth to track variable scope, function signatures, and type relationships.
# 28 layers should be sufficient based on CodeTito's success at that depth.
#
# Estimated params: ~800M

/// Code-optimized transformer block
/// Uses aggressive 4:1 GQA ratio for fast inference on code
neuron CodeBlock(dim, num_heads, kv_heads, d_ff):
    in: [batch, seq, dim]
    out: [batch, seq, dim]
    graph:
        # Attention with residual
        in -> (skip1, attn_path)
        attn_path ->
            RMSNorm(dim)
            GroupedQueryAttention(dim, num_heads, kv_heads)
            attn_out
        (skip1, attn_out) -> Add() -> mid

        # SwiGLU FFN with residual
        mid -> (skip2, ffn_path)
        ffn_path ->
            RMSNorm(dim)
            SwiGLU(dim, d_ff)
            ffn_out
        (skip2, ffn_out) -> Add() -> out


/// Code generation model — Llama-style at 800M
neuron WastelandCoderV1(vocab_size=16000, dim=1024, num_heads=16, kv_heads=4, d_ff=2816, layers=28):
    in: [batch, seq]
    out: [batch, seq, vocab_size]
    context:
        stack = unroll(layers):
            block = CodeBlock(dim, num_heads, kv_heads, d_ff)
    graph:
        in ->
            Embedding(vocab_size, dim)
            stack
            RMSNorm(dim)
            Linear(dim, vocab_size)
            out
