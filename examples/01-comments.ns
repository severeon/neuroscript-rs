# This is a single-line comment

# Comments can appear anywhere
neuron CommentTest(dim):  # inline comment
  # Comment before port
  in: [*, dim]  # comment after port
  out: [*, dim]
  # Comment before impl
  impl: core,nn/Identity  # comment after impl

# Multiple comment lines
# can appear in sequence
# like this

neuron AnotherTest:
  in: [*shape]
  out: [*shape]
  impl: core,nn/Identity
