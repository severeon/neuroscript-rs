# Test file for optimizer - has shadowed match arms

neuron Identity:
  in: [*shape]
  out: [*shape]
  impl: core,builtin/Identity

neuron Linear(in_dim, out_dim):
  in: [*, in_dim]
  out: [*, out_dim]
  impl: core,nn/Linear

# Match with shadowed arms (should be pruned by optimizer)
neuron TestShadowing:
  in: [*, dim]
  out: [*, 512]
  graph:
    in -> match:
      [*, 512]: Identity()
      [*, 256]: Linear(256, 512)  # This is shadowed by catch-all below
      [*, 1024]: Linear(1024, 512)  # This is also shadowed
      [*, d]: Linear(d, 512)  # Catch-all - shadows the two above
    -> out
