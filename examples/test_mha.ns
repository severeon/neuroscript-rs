# Test MultiHeadSelfAttention primitive

# Import the MultiHeadSelfAttention from stdlib
neuron MultiHeadSelfAttention(d_model, num_heads):
    in: [*batch, seq, d_model]
    out: [*batch, seq, d_model]
    impl: primitives,attention/MultiHeadSelfAttention

# Simple transformer-style neuron using MHA
neuron SimpleAttentionBlock(d_model, num_heads):
    in: [batch, seq, d_model]
    out: [batch, seq, d_model]
    graph:
        in -> MultiHeadSelfAttention(d_model, num_heads) -> out
