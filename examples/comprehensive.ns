# NeuroScript Language Demo
# Everything is a neuron. Neurons compose into neurons.

use core,nn/*
use core,activations/*

# === PRIMITIVES ===
# These wrap actual PyTorch implementations

neuron Linear(in_dim, out_dim):
  in: [*, in_dim]
  out: [*, out_dim]
  impl: core,nn/Linear

neuron Embedding(vocab, dim):
  in: [*batch, seq]
  out: [*batch, seq, dim]
  impl: core,nn/Embedding

neuron LayerNorm(dim):
  in: [*, dim]
  out: [*, dim]
  impl: core,nn/LayerNorm

neuron GELU:
  in: [*shape]
  out: [*shape]
  impl: core,activations/GELU

neuron Dropout(p=0.1):
  in: [*shape]
  out: [*shape]
  impl: core,nn/Dropout

neuron Softmax:
  in: [*shape]
  out: [*shape]
  impl: core,activations/Softmax

# === TOPOLOGY PRIMITIVES ===
# These control data flow

neuron Identity:
  in: [*shape]
  out: [*shape]
  impl: core,builtin/Identity

neuron Add:
  in left: [*shape]
  in right: [*shape]
  out: [*shape]
  impl: core,builtin/Add

neuron Concat(axis=-1):
  in left: [*shape]
  in right: [*shape]
  out: [*shape]
  impl: core,builtin/Concat

neuron Fork:
  in: [*shape]
  out a: [*shape]
  out b: [*shape]
  impl: core,builtin/Fork

neuron Fork3:
  in: [*shape]
  out a: [*shape]
  out b: [*shape]
  out c: [*shape]
  impl: core,builtin/Fork3

# === COMPOSITES ===
# Built purely from wiring other neurons

neuron MLP(dim, hidden_mult=4):
  in: [*, dim]
  out: [*, dim]
  graph:
    in ->
      Linear(dim, dim * hidden_mult)
      GELU()
      Dropout()
      Linear(dim * hidden_mult, dim)
      out

neuron ResidualMLP(dim):
  in: [*, dim]
  out: [*, dim]
  graph:
    in -> Fork() -> (main, skip)
    main -> MLP(dim) -> processed
    (processed, skip) -> Add() -> out

# Attention (simplified - real one would be more complex)
neuron Attention(dim, heads):
  in: [batch, seq, dim]
  out: [batch, seq, dim]
  graph:
    in -> Fork3() -> (q, k, v)
    q -> Linear(dim, dim) -> query
    k -> Linear(dim, dim) -> key
    v -> Linear(dim, dim) -> value
    # ... attention computation would happen here
    value -> Linear(dim, dim) -> out

neuron TransformerBlock(dim, heads):
  in: [batch, seq, dim]
  out: [batch, seq, dim]
  graph:
    # Pre-norm attention with residual
    in -> Fork() -> (attn_in, skip1)
    attn_in ->
      LayerNorm(dim)
      Attention(dim, heads)
      attn_out
    (attn_out, skip1) -> Add() -> post_attn

    # Pre-norm FFN with residual
    post_attn -> Fork() -> (ffn_in, skip2)
    ffn_in ->
      LayerNorm(dim)
      MLP(dim)
      ffn_out
    (ffn_out, skip2) -> Add() -> out

# === SHAPE-CONDITIONAL ROUTING ===

neuron AdaptiveProjection:
  in: [*, dim]
  out: [*, 512]
  graph:
    in -> match:
      [*, 512]: Identity() -> out
      [*, 256]: Linear(256, 512) -> out
      [*, d] where d > 512: Linear(d, 512) -> out
      [*, d]: Linear(d, 512) -> out

# === FULL MODEL ===

neuron SmallTransformer(vocab=50000, dim=512, layers=6, heads=8):
  in: [batch, seq]
  out: [batch, seq, vocab]
  graph:
    in ->
      Embedding(vocab, dim)
      # Stack would be: repeat TransformerBlock layers times
      TransformerBlock(dim, heads)
      TransformerBlock(dim, heads)
      TransformerBlock(dim, heads)
      TransformerBlock(dim, heads)
      TransformerBlock(dim, heads)
      TransformerBlock(dim, heads)
      LayerNorm(dim)
      Linear(dim, vocab)
      out

# === EXTERNAL INTEGRATION ===

neuron LMStudio(model):
  in: [batch, seq, vocab]
  out: [batch, seq_out, vocab]
  impl: external(provider=`lmstudio`, model=model)

neuron HybridPipeline:
  in: [batch, seq]
  out: [batch, seq_out, vocab]
  graph:
    in ->
      SmallTransformer()
      LMStudio(`qwen3-vl-12b`)
      out
