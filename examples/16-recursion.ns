use core,nn/Identity

neuron Identity():
  in: [*]
  out: [*]
  impl: core,nn/Identity
  
neuron MyNeuron(d_model, num_heads, d_ff, depth):
  in: [*, seq, d_model]
  out: [*, seq, d_model]
  context:
    @lazy recurse = MyNeuron(d_model, num_heads, d_ff, depth - 1)
  graph:
    in -> match:
      [*, seq, d_model] where depth > 0: recurse
      [*, seq, d_model]: Identity() -> out 
