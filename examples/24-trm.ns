# Tiny Recursive Model (TRM) - Based on Jolicoeur-Martineau 2025
# 7M params, beats most LLMs on ARC-AGI with recursive reasoning

use core,nn/*

# Primitives (assuming these exist or would be added)
neuron RMSNorm(dim):
  in: [*batch, seq, dim]
  out: [*batch, seq, dim]
  impl: core,nn/RMSNorm

neuron SwiGLU(dim):
  in: [*batch, seq, dim]
  out: [*batch, seq, dim]
  impl: core,activations/SwiGLU

# TRM uses MLP-Mixer style: MLP on sequence dimension instead of self-attention
# For fixed context length L <= D, this is more parameter efficient
neuron SeqMLP(seq_len):
  in: [*batch, seq_len, dim]
  out: [*batch, seq_len, dim]
  graph:
    # Transpose, apply MLP on seq dim, transpose back
    # Simplified: treat as learned mixing over sequence positions
    in ->
      Transpose(1, 2)
      Linear(seq_len, seq_len)
      SwiGLU(seq_len)
      Linear(seq_len, seq_len)
      Transpose(1, 2)
      out

# Core TRM block: 2-layer transformer-like structure
# Paper finding: 2 layers is optimal, more causes overfitting
neuron TRMBlock(d_model):
  in: [*batch, seq, d_model]
  out: [*batch, seq, d_model]
  graph:
    # Layer 1: Self-attention + residual
    in -> Fork() -> (main1, skip1)
    main1 ->
      RMSNorm(d_model)
      MultiHeadSelfAttention(d_model, 8)
      attn_out
    (attn_out, skip1) -> Add() -> post_attn

    # Layer 2: FFN + residual  
    post_attn -> Fork() -> (main2, skip2)
    main2 ->
      RMSNorm(d_model)
      Linear(d_model, d_model * 4)
      SwiGLU(d_model * 4)
      Linear(d_model * 4, d_model)
      ffn_out
    (ffn_out, skip2) -> Add() -> out

# Single reasoning step: update latent z given (x, y, z)
# The paper's key insight: same network handles both z-update and y-update
# distinguished only by whether x is included in input
neuron ReasoningStep(d_model):
  in x: [*batch, seq, d_model]
  in y: [*batch, seq, d_model]
  in z: [*batch, seq, d_model]
  out: [*batch, seq, d_model]
  graph:
    # Concatenate x + y + z, process, project back
    (x, y, z) -> Concatenate(dim=-1) -> combined
    combined ->
      Linear(d_model * 3, d_model)
      TRMBlock(d_model)
      TRMBlock(d_model)
      out

# Answer refinement: update y given (y, z) - no x input
neuron AnswerStep(d_model):
  in y: [*batch, seq, d_model]
  in z: [*batch, seq, d_model]
  out: [*batch, seq, d_model]
  graph:
    (y, z) -> Concatenate(dim=-1) -> combined
    combined ->
      Linear(d_model * 2, d_model)
      TRMBlock(d_model)
      TRMBlock(d_model)
      out

# One full recursion cycle: n reasoning steps then 1 answer step
# Paper uses n=6, T=3 for best results
neuron RecursionCycle(d_model):
  in x: [*batch, seq, d_model]
  in y: [*batch, seq, d_model]
  in z: [*batch, seq, d_model]
  out y_out: [*batch, seq, d_model]
  out z_out: [*batch, seq, d_model]
  context:
    @lazy step = sequential(6, ReasoningStep)
  graph:
    (x, y, z) -> step(d_model) -> z_out
    (y, z_out) -> AnswerStep(d_model) -> y_out

# Full TRM with T=3 recursion cycles
# Note: In practice, T-1 cycles run without gradients (handled by runtime)
neuron TRM(d_model, vocab_size, max_seq):
  in: [batch, seq]
  out: [batch, seq, vocab_size]
  context:
    @lazy cycle = RecursionCycle(d_model)
  graph:
    # Embed input question
    in ->
      Embedding(vocab_size, d_model)
      PositionalEncoding(d_model, max_len=max_seq)
      x_embedded

    x_embedded -> Fork() -> (x, y_init)
    x_embedded -> Identity() -> z_init

    (x, y_init, z_init) -> cycle -> (y1, z1)
    (x, y1, z1) -> cycle -> (y2, z2)
    (x, y2, z2) -> cycle -> (y_final, z_final)

    # Output head
    y_final ->
      RMSNorm(d_model)
      Linear(d_model, vocab_size)
      out
