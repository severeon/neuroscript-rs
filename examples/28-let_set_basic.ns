# Basic test of let/set bindings

neuron SimpleNetwork(dim):
  in: [*, dim]
  out: [*, dim]
  set:
    norm = LayerNorm(dim)
    ffn = FFN(dim, dim * 4)
  graph:
    in -> norm -> ffn -> out

neuron ConditionalNetwork(dim, use_extra):
  in: [*, dim]
  out: [*, dim]
  let:
    extra = Linear(dim, dim)
  set:
    main = Linear(dim, dim)
  graph:
    in -> match:
      [*, dim] where use_extra: extra -> main -> out
      [*, dim]: main -> out
