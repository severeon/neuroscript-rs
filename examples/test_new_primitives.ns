# Test file for new primitives: Fork, Add, Concat, ScaledDotProductAttention
# These primitives are already registered in the stdlib

neuron Fork:
  in: [*shape]
  out a: [*shape]
  out b: [*shape]
  impl: core,nn/Fork

neuron Add:
  in left: [*shape]
  in right: [*shape]
  out: [*shape]
  impl: core,nn/Add

neuron Concat(dim):
  in a: [*shape]
  in b: [*shape]
  out: [*shape]
  impl: core,nn/Concat

neuron ScaledDotProductAttention:
  in query: [*batch, seq_q, d_k]
  in key: [*batch, seq_k, d_k]
  in value: [*batch, seq_k, d_v]
  out: [*batch, seq_q, d_v]
  impl: core,nn/ScaledDotProductAttention

neuron Linear(in_features, out_features):
  in: [*, in_features]
  out: [*, out_features]
  impl: core,nn/Linear

# Test Fork and Add in a residual connection
neuron SimpleResidual(dim):
  in: [batch, seq, dim]
  out: [batch, seq, dim]
  graph:
    in -> Fork() -> (main, skip)
    main -> Linear(dim, dim) -> processed
    (processed, skip) -> Add() -> out

# Test Concat
neuron ConcatTest(dim):
  in: [batch, seq, dim]
  out: [batch, seq, dim * 2]
  graph:
    in -> Fork() -> (a, b)
    (a, b) -> Concat(-1) -> out

# Test ScaledDotProductAttention (self-attention)
neuron SelfAttention(d_model):
  in: [batch, seq, d_model]
  out: [batch, seq, d_model]
  graph:
    in -> Fork() -> (q, k_v)
    k_v -> Fork() -> (k, v)
    (q, k, v) -> ScaledDotProductAttention() -> out
