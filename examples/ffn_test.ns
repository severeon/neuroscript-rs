# Test example for FFN variant structure
# Demonstrates a simple FFN implementation

# Basic FFN test (inline definition, not using stdlib)
neuron SimpleFFN:
    in: [*, 512]
    out: [*, 512]
    graph:
        in ->
            Linear(512, 2048)
            GELU()
            Linear(2048, 512)
            out

# Gated FFN test
neuron TestGatedFFN:
    in: [*, 512]
    out: [*, 512]
    graph:
        in -> Fork() -> (gate_path, value_path)

        gate_path ->
            Linear(512, 2048)
            Sigmoid()
            gate

        value_path ->
            Linear(512, 2048)
            GELU()
            value

        (gate, value) -> Multiply() -> activated

        activated -> Linear(2048, 512) -> out
