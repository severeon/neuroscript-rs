# Value type examples

neuron CustomOp(size, rate, count, name, enabled):
  in: [*, size]
  out: [*, size]
  impl: core,custom/Op

# Integer values
neuron IntegerValues:
  in: [*, 512]
  out: [*, 256]
  impl: core,nn/Linear

# Negative integers
neuron NegativeIntegers(offset=-42):
  in: [*, 512]
  out: [*, 512]
  impl: core,nn/Linear

# Float values
neuron FloatValues(rate=0.1, scale=1.5, temp=2.7):
  in: [*, 512]
  out: [*, 512]
  impl: core,custom/Op

# Negative floats
neuron NegativeFloats(beta=-0.5, gamma=-1.2):
  in: [*, 512]
  out: [*, 512]
  impl: core,custom/Op

# String values (backtick)
neuron StringValues(model=`gpt-4`, mode=`inference`):
  in: [*, 512]
  out: [*, 512]
  impl: external(model=model, mode=mode)

# Boolean values
neuron BooleanValues(enabled=true, debug=false):
  in: [*, 512]
  out: [*, 512]
  impl: core,custom/Op

# Mixed value types
neuron MixedValues(size=512, rate=0.1, count=100, name=`default`, enabled=true, offset=-10, scale=-0.5):
  in: [*, 512]
  out: [*, size]
  impl: core,custom/Op

# Name references (parameters)
neuron NameReferences(dim, hidden, dropout_rate):
  in: [*, dim]
  out: [*, hidden]
  impl: core,custom/Op

# Zero and one
neuron SpecialNumbers(zero=0, one=1, minus_one=-1):
  in: [*, 512]
  out: [*, 512]
  impl: core,custom/Op
