# Unroll: @static weight sharing
# A single module instance is called N times in sequence

# Shared weights: same block called 3 times
neuron SharedLayers(d_model, num_heads, d_ff, num_layers=3):
    in: [*, seq, d_model]
    out: [*, seq, d_model]
    context:
        blocks = unroll(num_layers):
            @static block = TransformerBlock(d_model, num_heads, d_ff)
    graph:
        in ->
            blocks
            out
