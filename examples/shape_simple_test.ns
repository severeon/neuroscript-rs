# Simple shape validation test
# Using only registered primitives

# Test basic shape propagation
neuron SimpleTest():
    in input: [*, 512]
    out output: [*, 256]
    graph:
        in -> Linear(512, 256) -> out

# Test with Fork and Add
neuron TestForkAdd():
    in input: [*, 512]
    out output: [*, 512]
    graph:
        in -> Fork() -> (a, b)
        a -> Add() -> temp
        b -> temp
        temp -> out
