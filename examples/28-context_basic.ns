# Basic test of context bindings

neuron SimpleNetwork(dim):
  in: [*, dim]
  out: [*, dim]
  context:
    norm = LayerNorm(dim)
    ffn = FFN(dim, dim * 4)
  graph:
    in -> norm -> ffn -> out

neuron ConditionalNetwork(dim, use_extra):
  in: [*, dim]
  out: [*, dim]
  context:
    @lazy extra = Linear(dim, dim)
    main = Linear(dim, dim)
  graph:
    in -> match:
      [*, dim] where use_extra: extra -> main -> out
      [*, dim]: main -> out
