{
  "name": "neuroscript",
  "displayName": "NeuroScript",
  "description": "Syntax highlighting for the NeuroScript neural architecture composition language",
  "version": "0.1.0",
  "publisher": "neuroscript",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "neuroscript",
        "aliases": ["NeuroScript", "neuroscript"],
        "extensions": [".ns"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "neuroscript",
        "scopeName": "source.neuroscript",
        "path": "./syntaxes/neuroscript.tmLanguage.json"
      }
    ]
  }
}
