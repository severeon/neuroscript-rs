{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "NeuroScript",
  "scopeName": "source.neuroscript",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#annotations" },
    { "include": "#neuron-definition" },
    { "include": "#use-statement" },
    { "include": "#impl-section" },
    { "include": "#keywords" },
    { "include": "#booleans" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#shapes" },
    { "include": "#function-call" },
    { "include": "#type-reference" },
    { "include": "#identifiers" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.documentation.neuroscript",
          "match": "///.*$"
        },
        {
          "name": "comment.line.number-sign.neuroscript",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.other.backtick.neuroscript",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "constant.character.escape.neuroscript",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "match": "(@)(lazy|static|global)\\b",
          "captures": {
            "1": { "name": "punctuation.definition.annotation.neuroscript" },
            "2": { "name": "storage.modifier.neuroscript" }
          }
        }
      ]
    },
    "neuron-definition": {
      "patterns": [
        {
          "match": "\\b(neuron)\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.neuroscript" },
            "2": { "name": "entity.name.type.neuroscript" }
          }
        }
      ]
    },
    "use-statement": {
      "patterns": [
        {
          "match": "\\b(use)\\s+([a-z_][a-zA-Z0-9_]*)\\s*(,)\\s*([a-zA-Z0-9_/*]+(?:/[a-zA-Z0-9_/*]+)*)",
          "captures": {
            "1": { "name": "keyword.import.neuroscript" },
            "2": { "name": "entity.name.namespace.neuroscript" },
            "3": { "name": "punctuation.separator.neuroscript" },
            "4": { "name": "string.unquoted.impl-ref.neuroscript" }
          }
        }
      ]
    },
    "impl-section": {
      "patterns": [
        {
          "match": "\\b(impl)\\s*(:)\\s*([a-z_][a-zA-Z0-9_]*)\\s*(,)\\s*([a-zA-Z0-9_/*]+(?:/[a-zA-Z0-9_/*]+)*)",
          "captures": {
            "1": { "name": "keyword.other.section.neuroscript" },
            "2": { "name": "punctuation.separator.neuroscript" },
            "3": { "name": "entity.name.namespace.neuroscript" },
            "4": { "name": "punctuation.separator.neuroscript" },
            "5": { "name": "string.unquoted.impl-ref.neuroscript" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.other.port.neuroscript",
          "match": "\\b(in|out)\\b"
        },
        {
          "name": "keyword.other.section.neuroscript",
          "match": "\\b(graph|context)\\b"
        },
        {
          "name": "keyword.control.neuroscript",
          "match": "\\b(match|where)\\b"
        },
        {
          "name": "keyword.control.conditional.neuroscript",
          "match": "\\b(if|elif|else)\\b"
        },
        {
          "name": "keyword.control.loop.neuroscript",
          "match": "\\b(unroll)\\b"
        },
        {
          "name": "keyword.import.neuroscript",
          "match": "\\b(use)\\b"
        },
        {
          "name": "keyword.operator.logical.neuroscript",
          "match": "\\b(and|or)\\b"
        },
        {
          "name": "keyword.other.neuroscript",
          "match": "\\b(external)\\b"
        },
        {
          "name": "keyword.other.freeze.neuroscript",
          "match": "\\b(Freeze)\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.neuroscript",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.neuroscript",
          "match": "-?\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.neuroscript",
          "match": "-?\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.neuroscript",
          "match": "->"
        },
        {
          "name": "keyword.operator.comparison.neuroscript",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.neuroscript",
          "match": "(?<![=!<>])=(?!=)"
        },
        {
          "name": "keyword.operator.arithmetic.neuroscript",
          "match": "[+\\-*/]"
        }
      ]
    },
    "shapes": {
      "patterns": [
        {
          "begin": "\\[",
          "end": "\\]",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.shape.begin.neuroscript" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.shape.end.neuroscript" }
          },
          "name": "meta.shape.neuroscript",
          "patterns": [
            {
              "match": "(\\*)([a-z_][a-zA-Z0-9_]*)",
              "captures": {
                "1": { "name": "variable.language.wildcard.neuroscript" },
                "2": { "name": "variable.other.neuroscript" }
              }
            },
            {
              "name": "variable.language.wildcard.neuroscript",
              "match": "\\*"
            },
            {
              "name": "constant.numeric.integer.neuroscript",
              "match": "\\b[0-9]+\\b"
            },
            {
              "name": "keyword.operator.arithmetic.neuroscript",
              "match": "[+\\-*/]"
            },
            {
              "name": "variable.other.neuroscript",
              "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
            },
            {
              "name": "punctuation.separator.neuroscript",
              "match": ","
            }
          ]
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "match": "\\b([A-Z][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.neuroscript" }
          }
        }
      ]
    },
    "type-reference": {
      "patterns": [
        {
          "name": "entity.name.type.neuroscript",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.neuroscript",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.neuroscript",
          "match": "[,:]"
        },
        {
          "name": "punctuation.section.parens.neuroscript",
          "match": "[()]"
        },
        {
          "name": "punctuation.accessor.neuroscript",
          "match": "\\."
        }
      ]
    }
  }
}
