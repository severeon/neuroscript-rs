{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "`", "close": "`" }
  ],
  "surroundingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "`", "close": "`" }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(neuron|graph|context|impl|in|out|match|if|elif|else|unroll).*:\\s*$",
    "decreaseIndentPattern": "^\\s*$"
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
