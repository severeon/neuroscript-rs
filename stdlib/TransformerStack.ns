        #     )
        #     out


# Depth-scaled transformer (scales attention by depth)
# Used in some modern architectures to improve deep network training
neuron DepthScaledTransformerStack(num_layers, d_model, num_heads, d_ff):
    in: [batch, seq, d_model]
    out: [batch, seq, d_model]
    graph:
        # Each layer multiplies residual by alpha = 2 / sqrt(num_layers)
        # This helps gradient flow in very deep networks

        # Would need per-layer scaling factor
        # in
        #     ScaledTransformerBlock(d_model, num_heads, d_ff, scale=alpha)
        #     ... repeat with depth scaling ...
        #     out
        in -> TransformerStack(num_layers, d_model, num_heads, d_ff) -> out
